{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2021",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": ["src/**/*.ts"]
}
