{
	"name": "@ramz001-cinema/passport",
	"version": "1.0.2",
	"description": "A package for handling generation and verifications of authentication tokens.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"format": "prettier --write \"src/**/*.ts\"",
		"start": "node src/index.ts",
		"build": "tsc"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"keywords": [
		"authentication",
		"token"
	],
	"author": {
		"name": "Ramz",
		"email": "rkenjaev1@gmail.com"
	},
	"license": "ISC",
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"@nestjs/common": "^11.1.19",
		"@nestjs/core": "^11.1.19",
		"@ramz001-cinema/core": "^1.0.7",
		"@types/node": "^25.6.0",
		"jest": "^30.3.0",
		"prettier": "^3.8.3",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"typescript": "^6.0.3"
	}
}
